{
  "id": "assistant",
  "kind": "utility",
  "permissions": {
    "filesystem": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "persona": {
        "type": "string",
        "enum": ["kiera", "jarvis"],
        "default": "kiera"
      },
      "dailyBriefing": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "cronExpression": { "type": "string", "default": "0 8 * * *" },
          "timezone": { "type": "string" },
          "channels": { "type": "array", "items": { "type": "string" } }
        }
      },
      "taskManagement": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "maxTasks": { "type": "number", "default": 100 }
        }
      },
      "memoryIntegration": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "autoSummarize": { "type": "boolean", "default": true }
        }
      }
    },
    "required": []
  }
}
