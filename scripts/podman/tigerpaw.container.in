# Tigerpaw gateway — Podman Quadlet (rootless)
# Installed by setup-podman.sh into tigerpaw's ~/.config/containers/systemd/
# {{TIGERPAW_HOME}} is replaced at install time.

[Unit]
Description=Tigerpaw gateway (rootless Podman)

[Container]
Image=tigerpaw:local
ContainerName=tigerpaw
UserNS=keep-id
# Keep container UID/GID aligned with the invoking user so mounted config is readable.
User=%U:%G
Volume={{TIGERPAW_HOME}}/.tigerpaw:/home/node/.tigerpaw:Z
EnvironmentFile={{TIGERPAW_HOME}}/.tigerpaw/.env
Environment=HOME=/home/node
Environment=TERM=xterm-256color
PublishPort=18789:18789
PublishPort=18790:18790
Pull=never
Exec=node dist/index.js gateway --bind lan --port 18789

[Service]
TimeoutStartSec=300
Restart=on-failure

[Install]
WantedBy=default.target
